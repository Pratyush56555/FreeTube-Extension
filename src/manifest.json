{
  "manifest_version": 3,
  "name": "Play on FreeTube",
  "version": "2.0.0",
  "description": "Open YouTube videos, channels, and playlists in FreeTube app",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*",
    "*://youtu.be/*",
    "*://m.youtube.com/*",
    "*://music.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://youtube.com/*",
        "*://m.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png",
      "256": "icon.png"
    },
    "default_title": "FreeTube Extension"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png",
    "256": "icon.png"
  },
  "commands": {
    "open-in-freetube": {
      "suggested_key": {
        "default": "Alt+F",
        "windows": "Alt+F",
        "mac": "Alt+F",
        "linux": "Alt+F"
      },
      "description": "Open current video in FreeTube"
    }
  }
}